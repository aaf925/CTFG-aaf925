{
  "expo": {
    "name": "Asistente SmartHome",
    "slug": "smarthome-app",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Smarthome App to access your microphone.",
          "recordAudioAndroid": true
        }
      ],
      "expo-asset",
      "expo-video"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.asistentesmarthome",
      "softwareKeyboardLayoutMode": "pan",
      "androidNavigationBar": {
        "visible": "immersive",
        "backgroundColor": "#0D0D1A"
      },
      "androidStatusBar": {
        "translucent": true,
        "backgroundColor": "#0D0D1A"
      }
    }
  }
}
